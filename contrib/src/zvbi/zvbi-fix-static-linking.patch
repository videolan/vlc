From 897fae0fb25385f9d65888bdf8191cb207bd87b7 Mon Sep 17 00:00:00 2001
From: Pavlov Konstantin <thresh@videolan.org>
Date: Wed, 2 Nov 2016 10:36:47 +0100
Subject: [PATCH 5/9] fixed linking with static libpng

---
 configure.ac | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index 0288c88..4b2c000 100644
--- a/configure.ac
+++ b/configure.ac
@@ -317,7 +317,7 @@ dnl (PNG page export)
 dnl
 HAVE_PNG="yes"
 AC_CHECK_LIB(png, png_destroy_write_struct,
-  LIBS="$LIBS -lpng -lz", HAVE_PNG="no", -lz -lm)
+  LIBS="-lpng -lz $LIBS", HAVE_PNG="no", -lz -lm)
 if test "x$HAVE_PNG" = xyes; then
   AC_DEFINE(HAVE_LIBPNG, 1, [Define if you have libpng])
 fi
