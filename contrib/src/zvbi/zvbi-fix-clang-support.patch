From: =?UTF-8?q?Felix=20K=C3=BChne?= <fkuehne@videolan.org>
Date: Thu, 8 Aug 2013 21:41:55 +0200
Subject: [PATCH 04/11] fix compilation with clang

Simplified version of initial patch
---
 src/misc.h | 13 -------------
 1 file changed, 13 deletions(-)

diff --git a/src/misc.h b/src/misc.h
index ff8e96a..d0e965e 100644
--- a/src/misc.h
+++ b/src/misc.h
@@ -52,17 +52,6 @@
 #  define unlikely(expr) __builtin_expect(expr, 0)
 #endif
 
-#undef __i386__
-#undef __i686__
-/* FIXME #cpu is deprecated
-#if #cpu (i386)
-#  define __i386__ 1
-#endif
-#if #cpu (i686)
-#  define __i686__ 1
-#endif
-*/
-
 /* &x == PARENT (&x.tm_min, struct tm, tm_min),
    safer than &x == (struct tm *) &x.tm_min. A NULL _ptr is safe and
    will return NULL, not -offsetof(_member). */
@@ -156,8 +145,6 @@ do {									\
 
 #define likely(expr) (expr)
 #define unlikely(expr) (expr)
-#undef __i386__
-#undef __i686__
 
 static char *
 PARENT_HELPER (char *p, unsigned int offset)
