From 5509c9228ad044c3cdf94424b4224336dfa12c8e Mon Sep 17 00:00:00 2001
From: Steve Lhomme <robux4@ycbcr.xyz>
Date: Wed, 10 Apr 2024 15:37:48 +0200
Subject: [PATCH 7/9] fix Android usage of pthread

- pthread_create is not detected properly with the NDK26.
- pthread_cancel is called but it's not supported by Android, it's probably dead code that is removed during linking
---
 configure.ac | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index 4b2c000..9889d12 100644
--- a/configure.ac
+++ b/configure.ac
@@ -237,7 +237,7 @@ dnl
 dnl When upgrading to autoconf 2.71, AC_TRY_LINK deprecated and replaced
 dnl with AC_LINK_IFELSE.
 dnl
-AC_CHECK_LIB(pthread, pthread_create,,[
+AC_SEARCH_LIBS([pthread_create], [pthread pthreads],,[
   AC_CHECK_LIB(pthreadGC2, pthread_create,,[
     AC_LINK_IFELSE([AC_LANG_PROGRAM([[]], [[pthread_create();]])],[],[
       # same as previous, but use '-pthread' instead of '-lpthread'
-- 
2.52.0.windows.1

