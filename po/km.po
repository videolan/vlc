#: src/libvlc-module.c:409
msgid "Video snapshot width"
msgstr "бһ‘бһ‘бһ№бһ„вҖӢбһҡбһјбһ”бһҗбһҸвҖӢбһңбһёбһҠбҹҒбһўбһј"

